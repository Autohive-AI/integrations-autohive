{
  "name": "slider",
  "version": "1.0.0",
  "description": "Comprehensive PowerPoint presentation creation and manipulation integration",
  "entry_point": "slider.py",
  "actions": {
    "create_complete_presentation": {
      "display_name": "Create Complete Presentation",
      "description": "Create an entire presentation with unlimited slides, each with unique backgrounds, layouts, and content elements in a single operation",
      "input_schema": {
        "type": "object",
        "properties": {
          "presentation_metadata": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "Main presentation title"
              },
              "subtitle": {
                "type": "string", 
                "description": "Presentation subtitle"
              },
              "template_path": {
                "type": "string",
                "description": "Optional path to template PPTX file"
              }
            },
            "required": ["title"]
          },
          "slides": {
            "type": "array",
            "description": "Array of slide definitions - can contain unlimited slides",
            "minItems": 1,
            "maxItems": 1000,
            "items": {
              "type": "object",
              "properties": {
                "slide_index": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Position of slide in presentation"
                },
                "background": {
                  "oneOf": [
                    {
                      "type": "object",
                      "description": "Solid color background",
                      "properties": {
                        "type": {"const": "solid"},
                        "color": {
                          "oneOf": [
                            {
                              "type": "string",
                              "pattern": "^#[0-9A-Fa-f]{6}$",
                              "description": "Hex color code"
                            },
                            {
                              "type": "object",
                              "properties": {
                                "rgb": {
                                  "type": "array",
                                  "items": {"type": "integer", "minimum": 0, "maximum": 255},
                                  "minItems": 3,
                                  "maxItems": 3
                                }
                              },
                              "required": ["rgb"]
                            },
                            {
                              "type": "object",
                              "properties": {
                                "theme_color": {
                                  "enum": ["ACCENT_1", "ACCENT_2", "ACCENT_3", "ACCENT_4", "ACCENT_5", "ACCENT_6", "BACKGROUND_1", "BACKGROUND_2", "DARK_1", "DARK_2", "LIGHT_1", "LIGHT_2"]
                                }
                              },
                              "required": ["theme_color"]
                            }
                          ]
                        }
                      },
                      "required": ["type", "color"]
                    },
                    {
                      "type": "object",
                      "description": "Gradient background",
                      "properties": {
                        "type": {"const": "gradient"},
                        "angle": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 360,
                          "description": "Gradient angle in degrees"
                        },
                        "gradient_stops": {
                          "type": "array",
                          "minItems": 2,
                          "maxItems": 10,
                          "items": {
                            "type": "object",
                            "properties": {
                              "color": {
                                "oneOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "rgb": {
                                        "type": "array",
                                        "items": {"type": "integer", "minimum": 0, "maximum": 255},
                                        "minItems": 3,
                                        "maxItems": 3
                                      }
                                    },
                                    "required": ["rgb"]
                                  },
                                  {
                                    "type": "object",
                                    "properties": {
                                      "theme_color": {
                                        "enum": ["ACCENT_1", "ACCENT_2", "ACCENT_3", "ACCENT_4", "ACCENT_5", "ACCENT_6"]
                                      }
                                    },
                                    "required": ["theme_color"]
                                  }
                                ]
                              },
                              "position": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 1,
                                "description": "Position of gradient stop (0.0 to 1.0)"
                              }
                            },
                            "required": ["color", "position"]
                          }
                        }
                      },
                      "required": ["type", "gradient_stops"]
                    },
                    {
                      "type": "object",
                      "description": "Background image",
                      "properties": {
                        "type": {"const": "image"},
                        "image_data": {
                          "type": "string",
                          "description": "Base64 encoded image data"
                        },
                        "opacity": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1,
                          "default": 1,
                          "description": "Image opacity"
                        }
                      },
                      "required": ["type", "image_data"]
                    }
                  ],
                  "description": "Slide background configuration"
                },
                "elements": {
                  "type": "array",
                  "description": "Array of content elements on the slide",
                  "maxItems": 50,
                  "items": {
                    "oneOf": [
                      {
                        "type": "object",
                        "description": "Text element",
                        "properties": {
                          "element_type": {"const": "text"},
                          "text": {
                            "type": "string",
                            "minLength": 1,
                            "description": "Text content"
                          },
                          "position": {
                            "type": "object",
                            "properties": {
                              "left": {"type": "number", "description": "Left position in inches"},
                              "top": {"type": "number", "description": "Top position in inches"},
                              "width": {"type": "number", "description": "Width in inches"},
                              "height": {"type": "number", "description": "Height in inches"}
                            },
                            "required": ["left", "top", "width", "height"]
                          },
                          "formatting": {
                            "type": "object",
                            "properties": {
                              "font_size": {
                                "type": "integer",
                                "minimum": 8,
                                "maximum": 144,
                                "description": "Font size in points"
                              },
                              "bold": {"type": "boolean"},
                              "italic": {"type": "boolean"},
                              "color": {
                                "type": "string",
                                "pattern": "^#[0-9A-Fa-f]{6}$",
                                "description": "Text color in hex format"
                              },
                              "vertical_anchor": {
                                "enum": ["TOP", "MIDDLE", "BOTTOM"],
                                "description": "Vertical alignment within shape"
                              },
                              "autosize_type": {
                                "enum": ["NONE", "SHAPE_TO_FIT_TEXT", "TEXT_TO_FIT_SHAPE"],
                                "description": "Automatic sizing behavior"
                              },
                              "word_wrap": {
                                "type": "boolean",
                                "description": "Enable word wrapping"
                              },
                              "margins": {
                                "type": "object",
                                "properties": {
                                  "top": {"type": "number", "description": "Top margin in inches"},
                                  "bottom": {"type": "number", "description": "Bottom margin in inches"},
                                  "left": {"type": "number", "description": "Left margin in inches"},
                                  "right": {"type": "number", "description": "Right margin in inches"}
                                }
                              },
                              "fit_text": {
                                "type": "object",
                                "properties": {
                                  "max_size": {
                                    "type": "number",
                                    "minimum": 1,
                                    "maximum": 144,
                                    "description": "Maximum font size when auto-fitting"
                                  }
                                }
                              }
                            }
                          }
                        },
                        "required": ["element_type", "text", "position"]
                      },
                      {
                        "type": "object",
                        "description": "Chart element",
                        "properties": {
                          "element_type": {"const": "chart"},
                          "chart_type": {
                            "enum": ["column_clustered", "line", "pie", "bar_clustered", "area", "xy_scatter"],
                            "description": "Type of chart to create"
                          },
                          "position": {
                            "type": "object",
                            "properties": {
                              "left": {"type": "number"},
                              "top": {"type": "number"},
                              "width": {"type": "number"},
                              "height": {"type": "number"}
                            },
                            "required": ["left", "top", "width", "height"]
                          },
                          "data": {
                            "type": "object",
                            "properties": {
                              "categories": {
                                "type": "array",
                                "items": {"type": "string"},
                                "description": "Chart categories/labels"
                              },
                              "series": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "name": {"type": "string"},
                                    "values": {
                                      "type": "array",
                                      "items": {"type": "number"}
                                    }
                                  },
                                  "required": ["name", "values"]
                                }
                              }
                            },
                            "required": ["categories", "series"]
                          },
                          "styling": {
                            "type": "object",
                            "properties": {
                              "title": {"type": "string"},
                              "show_legend": {"type": "boolean"},
                              "color_scheme": {"type": "string"}
                            }
                          }
                        },
                        "required": ["element_type", "chart_type", "position", "data"]
                      },
                      {
                        "type": "object", 
                        "description": "Table element",
                        "properties": {
                          "element_type": {"const": "table"},
                          "rows": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "Number of table rows"
                          },
                          "cols": {
                            "type": "integer", 
                            "minimum": 1,
                            "description": "Number of table columns"
                          },
                          "position": {
                            "type": "object",
                            "properties": {
                              "left": {"type": "number"},
                              "top": {"type": "number"},
                              "width": {"type": "number"},
                              "height": {"type": "number"}
                            },
                            "required": ["left", "top", "width", "height"]
                          },
                          "data": {
                            "type": "array",
                            "description": "2D array of table data",
                            "items": {
                              "type": "array",
                              "items": {"type": "string"}
                            }
                          },
                          "styling": {
                            "type": "object",
                            "properties": {
                              "table_style": {
                                "type": "string",
                                "enum": ["NONE", "LIGHT_STYLE_1", "LIGHT_STYLE_2", "LIGHT_STYLE_3", "MEDIUM_STYLE_1", "MEDIUM_STYLE_2", "DARK_STYLE_1", "DARK_STYLE_2"],
                                "description": "PowerPoint table style"
                              },
                              "style_options": {
                                "type": "object",
                                "properties": {
                                  "first_row": {"type": "boolean"},
                                  "first_col": {"type": "boolean"},
                                  "last_row": {"type": "boolean"},
                                  "last_col": {"type": "boolean"},
                                  "banded_rows": {"type": "boolean"},
                                  "banded_cols": {"type": "boolean"}
                                }
                              },
                              "header_style": {
                                "type": "object",
                                "properties": {
                                  "background_color": {"type": "string"},
                                  "text_color": {"type": "string"},
                                  "bold": {"type": "boolean"}
                                }
                              },
                              "cell_style": {
                                "type": "object",
                                "properties": {
                                  "background_color": {"type": "string"},
                                  "text_color": {"type": "string"}
                                }
                              }
                            }
                          }
                        },
                        "required": ["element_type", "rows", "cols", "position"]
                      },
                      {
                        "type": "object",
                        "description": "Image element",
                        "properties": {
                          "element_type": {"const": "image"},
                          "image_source": {
                            "oneOf": [
                              {
                                "type": "object",
                                "description": "File reference",
                                "properties": {
                                  "type": {"const": "file_reference"},
                                  "fileId": {"type": "number"},
                                  "contentType": {"type": "string"},
                                  "ownerType": {"enum": ["conversation", "workspace"]},
                                  "name": {"type": "string"}
                                },
                                "required": ["type", "fileId", "contentType", "ownerType"]
                              },
                              {
                                "type": "object",
                                "description": "Base64 encoded image",
                                "properties": {
                                  "type": {"const": "base64"},
                                  "image_data": {"type": "string"}
                                },
                                "required": ["type", "image_data"]
                              }
                            ]
                          },
                          "position": {
                            "type": "object",
                            "properties": {
                              "left": {"type": "number"},
                              "top": {"type": "number"},
                              "width": {"type": "number"},
                              "height": {"type": "number"}
                            },
                            "required": ["left", "top"]
                          }
                        },
                        "required": ["element_type", "image_source", "position"]
                      },
                      {
                        "type": "object",
                        "description": "Bullet list element",
                        "properties": {
                          "element_type": {"const": "bullet_list"},
                          "bullet_items": {
                            "type": "array",
                            "description": "Array of bullet items with text and level",
                            "items": {
                              "type": "object",
                              "properties": {
                                "text": {
                                  "type": "string",
                                  "description": "The bullet text"
                                },
                                "level": {
                                  "type": "integer",
                                  "minimum": 0,
                                  "maximum": 8,
                                  "description": "Indentation level (0-8)"
                                }
                              },
                              "required": ["text"]
                            },
                            "minItems": 1
                          },
                          "position": {
                            "type": "object",
                            "properties": {
                              "left": {"type": "number"},
                              "top": {"type": "number"},
                              "width": {"type": "number"},
                              "height": {"type": "number"}
                            },
                            "required": ["left", "top", "width", "height"]
                          }
                        },
                        "required": ["element_type", "bullet_items", "position"]
                      }
                    ]
                  }
                }
              },
              "required": ["slide_index", "elements"]
            }
          },
          "global_settings": {
            "type": "object",
            "description": "Presentation-wide settings",
            "properties": {
              "theme": {
                "type": "string",
                "enum": ["default", "corporate", "modern", "creative", "academic"],
                "default": "default"
              },
              "slide_size": {
                "enum": ["16:9", "4:3", "custom"],
                "default": "16:9"
              },
              "default_font": {
                "type": "string",
                "default": "Calibri"
              },
              "color_scheme": {
                "type": "string",
                "enum": ["blue", "red", "green", "orange", "purple", "custom"]
              }
            }
          },
          "processing_options": {
            "type": "object",
            "description": "Options for handling large presentations",
            "properties": {
              "batch_size": {
                "type": "integer",
                "minimum": 1,
                "maximum": 50,
                "default": 10,
                "description": "Number of slides to process in each batch"
              },
              "enable_progress_callbacks": {
                "type": "boolean",
                "default": false,
                "description": "Enable progress reporting for large presentations"
              },
              "optimize_for_size": {
                "type": "boolean",
                "default": false,
                "description": "Optimize output file size"
              },
              "auto_arrange_shapes": {
                "type": "object",
                "properties": {
                  "enabled": {"type": "boolean", "default": false},
                  "arrangement_type": {
                    "enum": ["grid", "flow", "columns"],
                    "default": "grid"
                  },
                  "margin": {"type": "number", "default": 0.2}
                }
              }
            }
          }
        },
        "required": ["presentation_metadata", "slides"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the presentation was created successfully"
          },
          "presentation_id": {
            "type": "string",
            "description": "Generated presentation ID"
          },
          "file": {
            "type": "object",
            "description": "The created presentation file for streaming",
            "properties": {
              "content": {
                "type": "string",
                "description": "The file content encoded as base64"
              },
              "name": {
                "type": "string",
                "description": "The name of the file"
              },
              "contentType": {
                "type": "string",
                "description": "The content type of the file"
              }
            },
            "required": ["content", "name", "contentType"]
          },
          "slides_created": {
            "type": "integer",
            "description": "Number of slides created"
          },
          "elements_created": {
            "type": "integer",
            "description": "Total number of elements created across all slides"
          },
          "processing_time": {
            "type": "number",
            "description": "Time taken to create the presentation in seconds"
          },
          "warnings": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Any warnings encountered during creation"
          },
          "error": {
            "type": "string",
            "description": "Error message if creation failed"
          }
        },
        "required": ["success", "presentation_id", "file", "slides_created", "elements_created"]
      }
    }
  }
}